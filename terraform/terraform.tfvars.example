aws_region           = "ap-southeast-1"
project_name         = "goldenowl"
environment          = "dev"
availability_zones   = ["ap-southeast-1a", "ap-southeast-1b"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
container_port       = 3000
task_cpu             = 256
task_memory          = 512
desired_count        = 1
autoscaling_min      = 1
autoscaling_max      = 3
